#usda 1.0
(
    defaultPrim = "Conveyor"
    metersPerUnit = 1
    upAxis = "Z"
)

def Xform "Conveyor" (
    prepend references = @https://omniverse-content-production.s3-us-west-2.amazonaws.com/Assets/Isaac/5.1/Isaac/Props/Conveyors/ConveyorBelt_A01.usd@
)
{
    # Lab(100x) 아래 배치 시 정상 크기가 되도록 0.01 적용 (Lab 바깥이면 1.0 으로)
    float3 xformOp:scale = (0.01, 0.01, 0.01)
    uniform token[] xformOpOrder = ["xformOp:scale"]
}
